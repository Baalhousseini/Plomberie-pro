{
  "functions": {
    "api/*.js": {
      "memory": 256,
      "maxDuration": 10
    },
    "api/transcribe.js": {
      "memory": 512,
      "maxDuration": 30
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ]
}
